# Airtable (https://airtable.com) — one table holds waitlist emails like a spreadsheet.
#
# 1. Create a base and a table (default name: Waitlist).
# 2. Add fields: "Email" (Email or Single line text) and "Sign-up Date" (Date).
#    For a Date and time column instead, set AIRTABLE_SIGNUP_USE_DATETIME=true.
# 3. airtable.com/create/tokens — create a token with
#    data.records:read + data.records:write on that base.
#
# Base ID: open base → Help → API documentation (or URL appXXXXXXXXXXXXXX).

AIRTABLE_TOKEN=
AIRTABLE_BASE_ID=

# Optional (defaults shown):
# AIRTABLE_TABLE_NAME=Waitlist
# AIRTABLE_EMAIL_FIELD=Email
# AIRTABLE_SIGNUP_DATE_FIELD=Sign-up Date
# AIRTABLE_SIGNUP_USE_DATETIME=false
